<?xml version="1.0"?>
<robot name="simple_robot">

  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <material name="random_color">
    <color rgba="0.3 0.7 0 1"/>
  </material>

  <material name="grey">
    <color rgba="0.7 0.7 0.7 1"/>
  </material>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <material name="random_color"/>
    </visual>
  </link>

  <link name="second_link">
    <visual>
      <geometry>
        <cylinder length="0.25" radius="0.15"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="grey"/>
    </visual>
  </link>

  <link name="third_link">
    <visual>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <joint name="base_second_joint" type="continuous">
    <parent link="base_link"/>
    <child link="second_link"/>
    <origin xyz="0 0 1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="second_third_joint" type="prismatic">
    <parent link="second_link"/>
    <child link="third_link"/>
    <origin xyz="0 0.4 0.225" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.3" velocity="100" effort="100"/>
  </joint>

</robot>